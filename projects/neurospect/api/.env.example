# Database
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/neurospect
DATABASE_URL_SYNC=postgresql+psycopg2://user:pass@host:5432/neurospect

# JWT
JWT_SECRET=changeme
JWT_EXPIRE_MINUTES=43200

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Cloudflare R2
R2_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=neurospect-screenshots

# AI Coach — TradingView webhook
TRADINGVIEW_WEBHOOK_SECRET=changeme
# Comma-separated list. Empty = allowlist disabled (dev only).
TRADINGVIEW_IP_ALLOWLIST=52.89.214.238,34.212.75.30,54.218.53.128,52.32.178.7
PUBLIC_BASE_URL=http://localhost:8000

# AI Coach — Claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=2048
CLAUDE_TIMEOUT_SECONDS=30.0
AI_COACH_PROMPT_DIR=C:/Users/PaulRussell/repos/neurospect-wiki/concepts/ai-coach

# CORS — JSON list of allowed origins
CORS_ORIGINS=["http://localhost:5173"]

# Broker credentials encryption — REQUIRED
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BROKER_CRED_SECRET=

# Tradovate developer app credentials (from tradovate.com/developer)
# Without a real cid/sec, Tradovate triggers CAPTCHA (PRISM security) after 5 attempts/hour.
# Register a free developer app to get these. Default (cid=0, sec="") is dev-only.
TRADOVATE_APP_ID=NeurospectDev
TRADOVATE_CID=0
TRADOVATE_SEC=

# Linear (project management API)
LINEAR_API_KEY=

# Debug (never true in prod)
DEBUG=false
